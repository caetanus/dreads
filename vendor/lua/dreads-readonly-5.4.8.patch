+/*
+** dreads: mark/query a table as VM-level read-only. Every set path (VM fast and
+** slow, rawset/rawseti/rawsetp, setmetatable) then rejects writes to it, which no
+** amount of Lua-level metatable trickery can bypass. Used to seal the script
+** sandbox's shared globals and library tables against cross-script contamination.
+*/
+LUA_API void lua_enablereadonlytable (lua_State *L, int idx, int enabled) {
+  const TValue *o = index2value(L, idx);
+  api_check(L, ttistable(o), "table expected");
+  hvalue(o)->readonly = cast_byte(enabled ? 1 : 0);
+}
+
+
+LUA_API int lua_isreadonlytable (lua_State *L, int idx) {
+  const TValue *o = index2value(L, idx);
+  api_check(L, ttistable(o), "table expected");
+  return hvalue(o)->readonly;
+}
+
