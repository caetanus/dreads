/// Category name (without '@') -> its AclCat bit, or 0 if unknown.
uint aclCatBit(scope const(char)[] name) @safe nothrow @nogc
{
    switch (name)
    {
    case "admin": return AclCat.admin;
    case "bitmap": return AclCat.bitmap;
    case "blocking": return AclCat.blocking;
    case "cluster": return AclCat.cluster;
    case "connection": return AclCat.connection;
    case "dangerous": return AclCat.dangerous;
    case "fast": return AclCat.fast;
    case "generic": return AclCat.generic;
    case "geo": return AclCat.geo;
    case "hash": return AclCat.hash;
    case "hyperloglog": return AclCat.hyperloglog;
    case "keyspace": return AclCat.keyspace;
    case "list": return AclCat.list;
    case "pubsub": return AclCat.pubsub;
    case "read": return AclCat.read;
    case "scripting": return AclCat.scripting;
    case "sentinel": return AclCat.sentinel;
    case "server": return AclCat.server;
    case "set": return AclCat.set;
    case "slow": return AclCat.slow;
    case "sortedset": return AclCat.sortedset;
    case "stream": return AclCat.stream;
    case "string": return AclCat.string;
    case "transaction": return AclCat.transaction;
    case "write": return AclCat.write;
    default: return 0;
    }
}
