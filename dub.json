{
	"authors": [
		"Marcelo Aires Caetano"
	],
	"configurations": [
		{
			"name": "executable",
			"targetType": "executable"
		},
		{
			"dependencies": {
				"fluent-asserts": "*",
				"unit-threaded": "*"
			},
			"excludedSourceFiles": [
				"src/main.d"
			],
			"mainSourceFile": "bin/ut.d",
			"name": "unittest",
			"preBuildCommands": [
				"$DUB run --compiler=$$DC unit-threaded -c gen_ut_main -- -f bin/ut.d -d $DUB"
			],
			"targetName": "dreads_tests",
			"targetType": "executable"
		},
		{
			"name": "pubsub-bench",
			"excludedSourceFiles": [
				"source/app.d"
			],
			"mainSourceFile": "bench/pubsub_bench.d",
			"targetName": "pubsub_bench",
			"targetType": "executable"
		}
	],
	"copyright": "Copyright © 2025, Marcelo Aires Caetano",
	"dependencies": {
		"during": "~>0.3",
		"emplace": {
			"path": "vendor/emplace"
		},
		"draft": {
			"path": "vendor/raft"
		},
		"vibe-core": "~>2.8"
	},
	"description": "a dlang redis implementation",
	"dflags-ldc": [
		"-mcpu=x86-64-v3"
	],
	"libs": [
		"lua5.4"
	],
	"libs-linux": [
		"jemalloc"
	],
	"license": "MIT",
	"name": "dreads",
	"targetPath": "bin",
	"targetType": "executable"
}