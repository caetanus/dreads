{
	"authors": [
		"Marcelo Aires Caetano"
	],
	"configurations": [
		{
			"name": "executable",
			"targetType": "executable"
		},
		{
			"dependencies": {
				"fluent-asserts": "*",
				"unit-threaded": "*"
			},
			"excludedSourceFiles": [
				"src/main.d"
			],
			"mainSourceFile": "bin/ut.d",
			"name": "unittest",
			"preBuildCommands": [
				"$DUB run --compiler=$$DC unit-threaded -c gen_ut_main -- -f bin/ut.d -d $DUB",
				"sed -i -e 's/mixin runTestsMain!(/int main(string[] args) { import unit_threaded.runner.runner : runTests; return runTests!(/' -e 's/\");$$/\")(args ~ \"-s\"); }/' bin/ut.d"
			],
			"targetName": "dreads_tests",
			"targetType": "executable"
		},
		{
			"name": "pubsub-bench",
			"excludedSourceFiles": [
				"source/app.d"
			],
			"mainSourceFile": "bench/pubsub_bench.d",
			"targetName": "pubsub_bench",
			"targetType": "executable"
		},
		{
			"name": "lookup-bench",
			"excludedSourceFiles": [
				"source/app.d"
			],
			"mainSourceFile": "bench/lookup_bench.d",
			"targetName": "lookup_bench",
			"targetType": "executable"
		},
		{
			"name": "expire-bench",
			"excludedSourceFiles": [
				"source/app.d"
			],
			"mainSourceFile": "bench/expire_bench.d",
			"targetName": "expire_bench",
			"targetType": "executable"
		},
		{
			"name": "lazyfree-bench",
			"excludedSourceFiles": [
				"source/app.d"
			],
			"mainSourceFile": "bench/lazyfree_bench.d",
			"targetName": "lazyfree_bench",
			"targetType": "executable"
		},
		{
			"name": "lz4-bench",
			"excludedSourceFiles": [
				"source/app.d"
			],
			"mainSourceFile": "bench/lz4_bench.d",
			"targetName": "lz4_bench",
			"targetType": "executable"
		},
		{
			"name": "raft-auth-bench",
			"excludedSourceFiles": [
				"source/app.d"
			],
			"mainSourceFile": "bench/raft_auth_bench.d",
			"targetName": "raft_auth_bench",
			"targetType": "executable"
		}
	],
	"copyright": "Copyright © 2025, Marcelo Aires Caetano",
	"dependencies": {
		"during": "~>0.3",
		"emplace": {
			"path": "vendor/emplace"
		},
		"draft": {
			"path": "vendor/raft"
		},
		"libsodiumd": "~>0.2",
		"vibe-core": "~>2.8"
	},
	"description": "a dlang redis implementation",
	"dflags-ldc": [
		"-mcpu=x86-64-v3"
	],
	"preBuildCommands-posix": [
		"bash vendor/lua/build.sh",
		"bash vendor/lz4/build.sh"
	],
	"preBuildCommands-windows": [
		"pwsh -NoProfile -File vendor/lua/build.ps1",
		"pwsh -NoProfile -File vendor/lz4/build.ps1"
	],
	"lflags-posix": [
		"vendor/lua/build/liblua.a",
		"vendor/lz4/build/liblz4.a"
	],
	"lflags-windows": [
		"vendor/lua/build/liblua.lib",
		"vendor/lz4/build/liblz4.lib"
	],
	"libs": [
		"sodium"
	],
	"libs-linux": [
		"jemalloc"
	],
	"license": "MIT",
	"name": "dreads",
	"targetPath": "bin",
	"targetType": "executable"
}